# Copy to .env and fill in. .env is gitignored.

# Local dev Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://tfa:tfa_dev_pw@localhost:5432/trade_for_all

# Read-only connection for the internal admin dashboard (the tfa_ro role —
# GRANT SELECT only; see server/db/create_ro_role.sql). If unset in dev, the
# dashboard falls back to DATABASE_URL with a console warning. Point this at a
# prod DB's tfa_ro role (SSL + IP allowlist) to inspect cloud data locally.
DATABASE_URL_RO=

# Shared secret for the /api/admin gate (sent as the x-admin-token header). If
# unset, the admin API fails closed (401) — set a value to use the dashboard.
# The dashboard is also 404 whenever NODE_ENV=production.
ADMIN_TOKEN=

# Trade data source keys (Phase 1 fetch — not needed for schema+seed)
WTO_API_KEY=
UN_COMTRADE_API_KEY=

# Gemini (move server-side in Phase 1)
GEMINI_API_KEY=
