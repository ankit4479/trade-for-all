{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --platform=node --packages=external --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx server/db/seed.ts",
    "db:load:hs": "tsx server/loaders/hs-codes.ts",
    "db:load:country": "tsx server/loaders/wto-country.ts",
    "db:load:mfn": "tsx server/loaders/wto-mfn.ts",
    "db:load:all": "npm run db:load:hs && npm run db:load:country && npm run db:load:mfn"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@types/topojson-client": "^3.1.5",
    "@vis.gl/react-google-maps": "^1.7.1",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.36.4",
    "express": "^4.22.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "topojson-client": "^3.1.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "drizzle-kit": "^0.28.1",
    "esbuild": "^0.27.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
